# Copy to .env.local (git-ignored) and fill in from your Supabase project's
# Project Settings → API. Use the PUBLISHABLE / anon key — never service_role.
# With these unset, the app runs in demo mode (localStorage, no accounts).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-anon-key

# Public half of the Web Push VAPID key pair. Safe to ship to browsers.
VITE_VAPID_PUBLIC_KEY=

# --- Optional observability (dormant until set) ---
# Sentry error tracking — Project Settings → Client Keys (DSN)
VITE_SENTRY_DSN=
# PostHog product analytics — Project Settings → API keys
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# --- Server-side only, for the RLS test suite (NEVER ship to the browser) ---
# A DISPOSABLE test project's service_role key. Used only by
# supabase/tests/rls.test.mjs (Node), never imported by the app.
# SUPABASE_SERVICE_ROLE_KEY=your-test-project-service-role-key
